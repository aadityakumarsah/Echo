# ─── Clario environment variables ────────────────────────────────────────────
# Copy relevant sections to:
#   clario-backend/.env          (backend)
#   clario-frontend/.env.local   (frontend, Vite)
# Never commit real secrets.

# ════════════════════════════════════
# BACKEND  (clario-backend/.env)
# ════════════════════════════════════

# AI
GEMINI_API_KEY=your_gemini_api_key

# Supabase — Supabase Dashboard > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # service_role key (NEVER expose to frontend)
SUPABASE_JWT_SECRET=your-jwt-secret  # Settings > API > JWT Settings > JWT Secret

# Stripe — Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://your-app.vercel.app

# Optional
SECRET_KEY=change-me-in-production   # legacy JWT fallback
DB_PATH=/tmp/clario.db               # SQLite path (used as fallback)


# ════════════════════════════════════
# FRONTEND  (clario-frontend/.env.local)
# ════════════════════════════════════

# Backend API
VITE_BACKEND_BASE_URL=http://localhost:8000

# Supabase — Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # anon/public key (safe to expose)
